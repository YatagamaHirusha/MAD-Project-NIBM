<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Your Interests"
            android:textColor="#333333"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Select categories that describe you best"
            android:textColor="#757575"
            android:textSize="16sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_title" />

        <LinearLayout
            android:id="@+id/ll_categories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Relationship Intent -->
            <TextView style="@style/InterestCategoryHeader" android:text="Relationship Intent" />
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cg_relationship"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:chipSpacing="8dp" />

            <!-- Personality & Values -->
            <TextView style="@style/InterestCategoryHeader" android:text="Personality &amp; Values" />
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cg_personality"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:chipSpacing="8dp" />

            <!-- Lifestyle -->
            <TextView style="@style/InterestCategoryHeader" android:text="Lifestyle" />
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cg_lifestyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:chipSpacing="8dp" />

            <!-- Intellectual & Learning -->
            <TextView style="@style/InterestCategoryHeader" android:text="Intellectual &amp; Learning" />
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cg_intellectual"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:chipSpacing="8dp" />

            <!-- Food & Drinks -->
            <TextView style="@style/InterestCategoryHeader" android:text="Food &amp; Drinks" />
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cg_food"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:chipSpacing="8dp" />

            <!-- Travel & Culture -->
            <TextView style="@style/InterestCategoryHeader" android:text="Travel &amp; Culture" />
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cg_travel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:chipSpacing="8dp" />

            <!-- Gaming & Digital -->
            <TextView style="@style/InterestCategoryHeader" android:text="Gaming &amp; Digital" />
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cg_gaming"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:chipSpacing="8dp" />

            <!-- Sports & Outdoor -->
            <TextView style="@style/InterestCategoryHeader" android:text="Sports &amp; Outdoor" />
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cg_sports"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:chipSpacing="8dp" />

            <!-- Arts & Creativity -->
            <TextView style="@style/InterestCategoryHeader" android:text="Arts &amp; Creativity" />
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cg_arts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:chipSpacing="8dp" />

            <!-- Music -->
            <TextView style="@style/InterestCategoryHeader" android:text="Music" />
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cg_music"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:chipSpacing="8dp" />

            <!-- Movies & Shows -->
            <TextView style="@style/InterestCategoryHeader" android:text="Movies &amp; Shows" />
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cg_movies"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:chipSpacing="8dp" />

        </LinearLayout>

        <Button
            android:id="@+id/btn_save_interests"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="24dp"
            android:backgroundTint="#E91E63"
            android:text="Continue"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            app:cornerRadius="30dp"
            app:layout_constraintTop_toBottomOf="@id/ll_categories"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
